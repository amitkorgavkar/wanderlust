<% layout("/layouts/boilerplate") %>
<br><br>
<div class="row">
    <div class="col-8 offset-2">
        <h3>Edit your listing</h3>
        <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
            <div class="mb-3">
                <label for="title" class="form-lable">Title</label>
                <input type="text" value="<%= listing.title %>" name="listing[title]" class="form-control">
            </div>

            <div class="mb-3">
                <label for="description" class="form-lable">Description</label>
                <textarea name="description" class="form-control"><%= listing.description %></textarea>
            </div>

            <div class="mb-3">
                <label for="image" class="form-lable">Image</label>
                <input type="text" value="<%= listing.image %>" name="listing[image]" class="form-control">
            </div>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-lable">Price</label>
                    <input type="number" value="<%= listing.price %>" name="listing[price]" class="form-control">
                </div>

                <div class="mb-3 col-md-8">
                    <label for="country" class="form-lable">Country</label>
                    <input type="text" value="<%= listing.country %>" name="listing[country]" class="form-control">
                </div>
            </div>
    
            <div class="mb-3">
                <label for="location" class="form-lable">Location</label>
                <input type="text" value="<%= listing.location %>" name="listing[location]" class="form-control">
            </div>
            <button class="btn btn-dark mt-3 mb-3 edit-btn">Edit</button>
        </form>
    </div>
</div>